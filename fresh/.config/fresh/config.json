{
  "version": 2,
  "theme": "onedark.json",
  "locale": "en",
  "editor": {
    "cursor_style": "blinking_bar"
  },
  "file_explorer": {
    "show_hidden": true,
    "show_gitignored": true
  },
  "lsp": {
    "json": {
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    },
    "jsonc": {
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    },
    "markdown": {
      "enabled": true,
      "auto_start": true,
      "process_limits": {
        "max_memory_percent": 50,
        "max_cpu_percent": 90,
        "enabled": true
      }
    }
  }
}